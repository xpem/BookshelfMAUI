<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Bookshelf.Views.Historic"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:Icons="clr-namespace:Models;assembly=Models"
    xmlns:model="clr-namespace:Models.Books.Historic;assembly=Models"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:vm="clr-namespace:Bookshelf.ViewModels"
    x:Name="this"
    x:DataType="vm:HistoricVM"
    Style="{StaticResource ContentPage}">

    <Shell.TitleView>
        <HorizontalStackLayout Margin="10,0,0,0" Spacing="8" VerticalOptions="Center">
            <Label
                FontFamily="FontAwesome"
                FontSize="17"
                Text="{x:Static Icons:IconFont.History}"
                TextColor="{StaticResource White}"
                VerticalOptions="Center" />
            <Label
                FontSize="17"
                Text="Histórico"
                TextColor="{StaticResource White}"
                VerticalOptions="Center" />
        </HorizontalStackLayout>
    </Shell.TitleView>
    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
            BindingContext="{Binding BindingContext, Source={x:Reference this}, x:DataType=HistoricVM}"
            Command="{Binding AppearingCommand}"
            EventName="Appearing" />
    </ContentPage.Behaviors>
    <ContentPage.Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Label
                Grid.Row="0"
                FontFamily="EBGaramondSemiBold"
                FontSize="15"
                HorizontalOptions="Center"
                IsVisible="{Binding IsNotSyncUpdates}"
                Text="Há alterações não sincronizadas!"
                TextColor="{StaticResource WarningColor}" />
            <Button
                Grid.Row="1"
                BackgroundColor="{Binding SyncProcessingColor}"
                CornerRadius="20"
                HeightRequest="40"
                HorizontalOptions="Center"
                IsEnabled="{Binding SyncOptionIsProcessing}"
                IsVisible="{Binding SyncOptionIsVisible}"
                WidthRequest="40">
                <Button.ImageSource>
                    <FontImageSource
                        FontFamily="FontAwesome"
                        Glyph="{x:Static Icons:IconFont.Sync}"
                        Size="15"
                        Color="Black" />
                </Button.ImageSource>
            </Button>
            <Border
                Grid.Row="2"
                Margin="5"
                Padding="5"
                BackgroundColor="Transparent"
                StrokeShape="RoundRectangle 10">
                <CollectionView
                    Margin="0"
                    ItemsSource="{Binding UIBookHistoricList}"
                    RemainingItemsThreshold="2"
                    RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="model:UIBookHistoric">
                            <Border
                                Margin="0,0,0,5"
                                Padding="10"
                                BackgroundColor="Transparent">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="8*" />
                                    </Grid.ColumnDefinitions>
                                    <Button
                                        Grid.Row="1"
                                        Margin="10,0,0,0"
                                        BackgroundColor="{StaticResource ActiveColor}"
                                        ContentLayout="Top,0"
                                        CornerRadius="20"
                                        HeightRequest="40"
                                        HorizontalOptions="End"
                                        VerticalOptions="End"
                                        WidthRequest="40">
                                        <Button.ImageSource>
                                            <FontImageSource
                                                FontFamily="FontAwesome"
                                                Glyph="{Binding BookHistoricIcon}"
                                                Size="15"
                                                Color="Black" />
                                        </Button.ImageSource>
                                    </Button>
                                    <Label
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Margin="10,10,0,0"
                                        FontAttributes="Italic"
                                        Text="{Binding HistoricDate}"
                                        TextColor="White" />
                                    <Border
                                        Grid.Column="1"
                                        Margin="0,10,0,0"
                                        Padding="20,10"
                                        BackgroundColor="#101923"
                                        HorizontalOptions="Fill"
                                        Stroke="#51555B"
                                        StrokeShape="RoundRectangle 20,20,0,20"
                                        VerticalOptions="Start">
                                        <Label
                                            Padding="5"
                                            FontSize="18"
                                            HorizontalOptions="Start"
                                            Text="{Binding BookHistoricText}"
                                            TextColor="White"
                                            TextType="Html" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    <CollectionView.Footer>
                        <Grid Padding="6" IsVisible="{Binding IsBusy}">
                            <Grid.Triggers>
                                <Trigger TargetType="Grid" Property="IsVisible" Value="False">
                                    <Setter Property="HeightRequest" Value="0" />
                                </Trigger>
                            </Grid.Triggers>
                            <ActivityIndicator
                                HorizontalOptions="Center"
                                IsRunning="{Binding IsBusy}"
                                IsVisible="{Binding IsBusy}"
                                VerticalOptions="Center"
                                Color="{StaticResource ActiveColor}" />
                        </Grid>
                    </CollectionView.Footer>
                </CollectionView>
            </Border>
        </Grid>
    </ContentPage.Content>
</ContentPage>