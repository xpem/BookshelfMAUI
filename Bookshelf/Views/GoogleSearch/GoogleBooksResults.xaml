<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Bookshelf.Views.GoogleSearch.GoogleBooksResults"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:Icons="clr-namespace:Models;assembly=Models"
    xmlns:components="clr-namespace:Bookshelf.Components"
    xmlns:model="clr-namespace:Models.Books.GoogleApi;assembly=Models"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:vm="clr-namespace:Bookshelf.ViewModels.GoogleSearch"
    x:Name="this"
    x:DataType="vm:GoogleBooksResultsVM"
    Style="{StaticResource ContentPage}">

    <Shell.TitleView>
        <HorizontalStackLayout
            Margin="10,0,0,0"
            Spacing="8"
            VerticalOptions="Center">
            <Label
                FontFamily="FontAwesome"
                FontSize="20"
                Text="{x:Static Icons:IconFont.Search}"
                TextColor="{StaticResource White}"
                VerticalOptions="Center" />
            <Label
                FontSize="17"
                Text="{Binding PageTitle}"
                TextColor="{StaticResource White}"
                VerticalOptions="Center" />
        </HorizontalStackLayout>
    </Shell.TitleView>
    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
            BindingContext="{Binding BindingContext, Source={x:Reference this}, x:DataType=GoogleBooksResultsVM}"
            Command="{Binding AppearingCommand}"
            EventName="Appearing" />
    </ContentPage.Behaviors>
    <ContentPage.Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border
                Grid.Row="0"
                Padding="10,0,10,5"
                HorizontalOptions="Fill"
                Style="{StaticResource BorderPrimary}">
                <StackLayout Margin="0" IsEnabled="{Binding IsConnected}">
                    <components:BorderedEntry
                        LabelText="Digite o título do livro"
                        MaxLength="100"
                        Text="{Binding SearchText}" />
                </StackLayout>
            </Border>
            <Border
                Grid.Row="1"
                Margin="5"
                Padding="5"
                BackgroundColor="Transparent"
                StrokeShape="RoundRectangle 10">
                <Grid>
                    <Label
                        Margin="0,0,0,10"
                        FontFamily="FontAwesome"
                        FontSize="40"
                        HorizontalOptions="Center"
                        IsVisible="{Binding IsNotConnected}"
                        SemanticProperties.Description="Status da conexão"
                        Text="{x:Static Icons:IconFont.Wifi}"
                        TextColor="{x:Static Colors.Red}"
                        VerticalOptions="Center" />
                    <CollectionView
                        IsVisible="{Binding IsConnected}"
                        ItemsSource="{Binding GoogleBooksList}"
                        RemainingItemsThreshold="2"
                        RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}"
                        SelectionChanged="CollectionView_SelectionChanged"
                        SelectionMode="Single">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="model:UIGoogleBook">
                                <Border
                                    Margin="0,0,0,5"
                                    Padding="10"
                                    BackgroundColor="#101923"
                                    Stroke="#2B659B"
                                    StrokeShape="RoundRectangle 10">
                                    <StackLayout HorizontalOptions="Fill" Orientation="Vertical">
                                        <Label
                                            FontFamily="EBGaramondSemiBold"
                                            FontSize="20"
                                            LineBreakMode="TailTruncation"
                                            MaxLines="1"
                                            Text="{Binding Title}"
                                            TextColor="#98BDD3" />
                                        <Grid HeightRequest="150" HorizontalOptions="Fill">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="20" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="3*" />
                                                <ColumnDefinition Width="6*" />
                                            </Grid.ColumnDefinitions>
                                            <Image
                                                Grid.RowSpan="4"
                                                Grid.Column="1"
                                                Aspect="AspectFit"
                                                HorizontalOptions="End"
                                                Source="{Binding Thumbnail}" />
                                            <Label
                                                FontFamily="EBGaramondRegular"
                                                FontSize="15"
                                                HorizontalTextAlignment="Start"
                                                LineBreakMode="TailTruncation"
                                                Text="{Binding Authors}"
                                                TextColor="#98BDD3"
                                                VerticalTextAlignment="Start" />
                                            <Label
                                                Grid.Row="1"
                                                Grid.Column="0"
                                                FontFamily="EBGaramondRegular"
                                                FontSize="15"
                                                HorizontalTextAlignment="Start"
                                                LineBreakMode="TailTruncation"
                                                Text="{Binding PageCount, StringFormat='Páginas: {0:F0}'}"
                                                TextColor="White"
                                                VerticalTextAlignment="Start" />
                                        </Grid>
                                    </StackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                        <CollectionView.Footer>
                            <Grid Padding="6" IsVisible="{Binding IsBusy}">
                                <Grid.Triggers>
                                    <Trigger TargetType="Grid" Property="IsVisible" Value="False">
                                        <Setter Property="HeightRequest" Value="0" />
                                    </Trigger>
                                </Grid.Triggers>
                                <ActivityIndicator
                                    HorizontalOptions="Center"
                                    IsRunning="{Binding IsBusy}"
                                    IsVisible="{Binding IsBusy}"
                                    VerticalOptions="Center"
                                    Color="#2196F3" />
                            </Grid>
                        </CollectionView.Footer>
                    </CollectionView>
                    <Button
                        Command="{Binding CreateBookCommand}"
                        ContentLayout="Top,0"
                        CornerRadius="50"
                        HeightRequest="65"
                        HorizontalOptions="End"
                        Style="{StaticResource BtnPrimary}"
                        VerticalOptions="End"
                        WidthRequest="65">
                        <Button.ImageSource>
                            <FontImageSource
                                FontFamily="FontAwesome"
                                Glyph="{x:Static Icons:IconFont.Plus}"
                                Size="30"
                                Color="Black" />
                        </Button.ImageSource>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </ContentPage.Content>
</ContentPage>